# https://access.redhat.com/documentation/en-us/red_hat_enterprise_linux/6/html/systemtap_beginners_guide/futexcontentionsect
# with adaptions for more recent kernel (cf. FUTEX_CMD_MASK)

# This script tries to identify contended user-space locks by hooking
# into the futex system call.

global thread_thislock # short
global thread_blocktime #
global slept
global FUTEX_WAIT = 0 /*, FUTEX_WAKE = 1 */

global lock_waits_block # long-lived stats on (tid,lock) blockage elapsed time
global lock_waits_spun

probe syscall.futex {  
  if(pid()!=target()) next
  if (op&0x7f != FUTEX_WAIT) next # don't care about WAKE event originator
  t = tid ()
  thread_thislock[t] = futex_uaddr
  thread_blocktime[t] = gettimeofday_us()
}

probe scheduler.ctxswitch {
  t = tid()
  if(pid()!=target() || !thread_thislock[t]) next
  slept[t] = 1
}

probe syscall.futex.return {  
  if(pid()!=target()) next
  t = tid()
  ts = thread_blocktime[t]
  if (ts) {
    elapsed = gettimeofday_us() - ts
    if (slept[t]) {
      delete slept[t]
      lock_waits_block[t, thread_thislock[t]] <<< elapsed
    } else {
      lock_waits_spun[t, thread_thislock[t]] <<< elapsed
    }
    delete thread_blocktime[t]
    delete thread_thislock[t]
  }
}

probe begin {
    printf("Start with target=%d...\n", target())
}
probe end {
  printf("Contention with context switch\n")
  foreach ([tid+, lock] in lock_waits_block)
    printf ("[%d] lock %p contended %d times, %d avg %d max us\n",
            tid, lock, @count(lock_waits_block[tid,lock]),
            @avg(lock_waits_block[tid,lock]),
            @max(lock_waits_block[tid,lock]))

  printf("\nContention without context switch\n")
  foreach ([tid+, lock] in lock_waits_spun)
    printf ("[%d] lock %p contended %d times, %d avg %d max us\n",
            tid, lock, @count(lock_waits_spun[tid,lock]),
            @avg(lock_waits_spun[tid,lock]),
            @max(lock_waits_spun[tid,lock]))
}
